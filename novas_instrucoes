apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: movies-quarkus
  namespace: cinema
spec:
  parentRefs:
    - name: ingress-gateway
      namespace: api-gateway
  rules:
    - name: movies                      # <- regra nomeada "movies"
      matches:
        - path: { type: Exact, value: /api/v1/movies }
          method: GET
        - path: { type: Exact, value: /api/v1/movies/drama }
          method: GET
        - path: { type: Exact, value: /api/v1/movies/comedia }
          method: GET
        - path: { type: Exact, value: /api/v1/movies }
          method: POST
      backendRefs:
        - name: <nome-do-service-em-cinema>
          port: 8080
    - name: directors                       # <- regra nomeada "directors"
      matches:
        - path: { type: Exact, value: /api/v1/directors }
          method: GET
      backendRefs:
        - name: <nome-do-service-em-cinema>
          port: 8080

---
apiVersion: kuadrant.io/v1
kind: AuthPolicy
metadata:
  name: movies-quarkus-auth
  namespace: cinema
spec:
  targetRef:
    group: gateway.networking.k8s.io
    kind: HTTPRoute
    name: movies-quarkus
    sectionName: movies                 # <- mira a regra "movies"
  defaults:
    rules:
      authentication:
        "api-key-users":
          apiKey:
            selector:
              matchLabels:
                app: movies-quarkus
            allNamespaces: true
          credentials:
            authorizationHeader:
              prefix: APIKEY
      response:
        success:
          filters:
            "identity":
              json:
                properties:
                  "userid":
                    selector: auth.identity.metadata.annotations.secret\.kuadrant\.io/user-id
--- 
apiVersion: kuadrant.io/v1
kind: AuthPolicy
metadata:
  name: movies-quarkus-directors-auth
  namespace: cinema
spec:
  targetRef:
    group: gateway.networking.k8s.io
    kind: HTTPRoute
    name: movies-quarkus
    sectionName: directors                  # <- mira a regra "directors"
  defaults:
    rules:
      authentication:
        "api-key-users":
          apiKey:
            selector:
              matchLabels:
                app: movies-quarkus
            allNamespaces: true
          credentials:
            authorizationHeader:
              prefix: APIKEY
      authorization:
        "web-only":
          patternMatching:
            patterns:
              - predicate: |
                  auth.identity.metadata.annotations["secret.kuadrant.io/user-id"] == "web-app"
      response:
        success:
          filters:
            "identity":
              json:
                properties:
                  "userid":
                    selector: auth.identity.metadata.annotations.secret\.kuadrant\.io/user-id
        unauthorized:
          headers:
            "content-type":
              value: application/json
          body:
            value: |
              {
                "error": "Forbidden",
                "message": "Este endpoint está disponível apenas para o web-app."
              }